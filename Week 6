<!DOCTYPE html>
<html>
<head>
<title>GK Quiz</title>

<style>

body{
    font-family: Arial;
    background: linear-gradient(135deg, #89f7fe, #66a6ff, #c3ec52);
    text-align: center;
}

.quiz-box{
    background: white;
    width: 60%;
    margin: auto;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 0 15px gray;
}

h1{
    color: #ff4d6d;
}

.question{
    margin: 20px 0;
    text-align: center;
    font-size: 18px;
}

.options{
    margin-top: 10px;
}

button{
    background: #ff7a18;
    color: white;
    border: none;
    padding: 12px 25px;
    font-size: 16px;
    border-radius: 8px;
    cursor: pointer;
}

button:hover{
    background: #e86a10;
}

#result{
    font-size: 22px;
    margin-top: 20px;
    color: #333;
}

</style>

</head>

<body>

<div class="quiz-box">

<h1>General Knowledge Quiz</h1>

<form id="quizForm">

<div class="question">
<p>1. What is the capital of India?</p>
<div class="options">
<input type="radio" name="q1" value="a"> Mumbai<br>
<input type="radio" name="q1" value="b"> New Delhi<br>
<input type="radio" name="q1" value="c"> Kolkata<br>
</div>
</div>

<div class="question">
<p>2. Which planet is known as the Red Planet?</p>
<div class="options">
<input type="radio" name="q2" value="a"> Earth<br>
<input type="radio" name="q2" value="b"> Mars<br>
<input type="radio" name="q2" value="c"> Venus<br>
</div>
</div>

<div class="question">
<p>3. Who wrote the Indian National Anthem?</p>
<div class="options">
<input type="radio" name="q3" value="a"> Rabindranath Tagore<br>
<input type="radio" name="q3" value="b"> Mahatma Gandhi<br>
<input type="radio" name="q3" value="c"> Subhas Chandra Bose<br>
</div>
</div>

<div class="question">
<p>4. Which is the largest ocean in the world?</p>
<div class="options">
<input type="radio" name="q4" value="a"> Atlantic Ocean<br>
<input type="radio" name="q4" value="b"> Pacific Ocean<br>
<input type="radio" name="q4" value="c"> Indian Ocean<br>
</div>
</div>

<div class="question">
<p>5. How many continents are there on Earth?</p>
<div class="options">
<input type="radio" name="q5" value="a"> 5<br>
<input type="radio" name="q5" value="b"> 6<br>
<input type="radio" name="q5" value="c"> 7<br>
</div>
</div>

<button type="button" onclick="checkQuiz()">Submit</button>

</form>

<p id="result"></p>

</div>

<script>

function checkQuiz(){

let score = 0;

let answers = {
q1:"b",
q2:"b",
q3:"a",
q4:"b",
q5:"c"
};

let form = document.forms["quizForm"];

for(let q in answers){
if(form[q].value === answers[q]){
score++;
}
}

document.getElementById("result").innerHTML =
"Your Score: " + score + " / 5";

}

</script>

</body>
</html>
