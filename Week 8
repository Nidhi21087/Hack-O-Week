<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Midnight Aperture Studios</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}

body{
  font-family:'Segoe UI', Tahoma, sans-serif;
  color:#eee;
  background:linear-gradient(140deg,#0f172a,#020617,#111827);
}

/* NAVBAR */
nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 50px;
  background:#020617;
  border-bottom:1px solid rgba(255,255,255,0.08);
  position:sticky;
  top:0;
  z-index:1000;
}

nav h2{
  letter-spacing:2px;
  color:#f1f5f9;
}

nav ul{
  list-style:none;
  display:flex;
  gap:30px;
}

nav a{
  text-decoration:none;
  color:#cbd5f5;
  font-weight:500;
  transition:color .3s;
}

nav a:hover{
  color:#ffffff;
}

header{
  text-align:center;
  padding:80px 20px 60px;
}

header h1{
  font-size:48px;
  margin-bottom:10px;
  color:#f8fafc;
}

header p{
  color:#cbd5e1;
}

section{
  max-width:1200px;
  margin:auto;
  padding:40px 30px 70px;
}

section h2{
  font-size:30px;
  margin-bottom:30px;
  text-align:center;
  letter-spacing:1px;
  color:#f1f5f9;
}

.gallery{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:25px;
}

.photo-card{
  background:#0f172a;
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 10px 25px rgba(0,0,0,0.6);
  transition:transform .35s, box-shadow .35s;
}

.photo-card:hover{
  transform:translateY(-8px);
  box-shadow:0 20px 45px rgba(0,0,0,0.8);
}

.photo-card img{
  width:100%;
  height:200px;
  object-fit:cover;
  cursor:pointer;
}

.photo-info{
  padding:14px 16px;
  font-size:14px;
  color:#cbd5e1;
}

/* LIGHTBOX */
.lightbox{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.95);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:2000;
}

.lightbox img{
  max-width:90%;
  max-height:85%;
  border-radius:10px;
}

.close-btn{
  position:absolute;
  top:30px;
  right:45px;
  font-size:42px;
  color:white;
  cursor:pointer;
}

footer{
  text-align:center;
  padding:40px 20px;
  color:#94a3b8;
  font-size:14px;
}

</style>
</head>

<body>

<nav>
  <h2>Midnight Aperture</h2>
  <ul>
    <li><a href="#nature">Nature</a></li>
    <li><a href="#city">City Life</a></li>
    <li><a href="#animals">Animals</a></li>
  </ul>
</nav>

<header>
  <h1>Echoes Through the Lens</h1>
  <p>A curated journey through landscapes, cities and wildlife captured by the lens of a wanderer</p>
</header>

<section id="nature">
  <h2>Whispers of the Wild</h2>
  <div class="gallery">

    <div class="photo-card">
      <img src="https://picsum.photos/id/1015/800/600" onclick="openLightbox(this.src)">
      <div class="photo-info">Misty mountains and quiet forests</div>
    </div>

    <div class="photo-card">
      <img src="https://www.japan.go.jp/kizuna/_src/7988222/202012_p04-05_01.jpg?v=1760945198119" onclick="openLightbox(this.src)">
      <div class="photo-info">Nature's calm landscapes</div>
    </div>

    <div class="photo-card">
      <img src="https://static.vecteezy.com/system/resources/thumbnails/067/967/023/small/majestic-mountain-peak-above-lush-green-hills-photo.jpeg" onclick="openLightbox(this.src)">
      <div class="photo-info">Untouched wilderness</div>
    </div>

  </div>
</section>

<section id="city">
  <h2>Urban Pulse</h2>
  <div class="gallery">

    <div class="photo-card">
      <img src="https://media-cdn.tripadvisor.com/media/photo-s/31/80/70/6a/premier-rooms-with-semi.jpg" onclick="openLightbox(this.src)">
      <div class="photo-info">Culture and architecture</div>
    </div>

    <div class="photo-card">
      <img src="https://media.istockphoto.com/id/901224272/photo/hollywood-boulevard-california.jpg?s=612x612&w=0&k=20&c=i4tXGT2-2dWDW3SJawcO30Zct513eP86KuC_DQmGFK8=" onclick="openLightbox(this.src)">
      <div class="photo-info">Life in motion</div>
    </div>

    <div class="photo-card">
      <img src="https://live.staticflickr.com/8564/16411170707_9be26c1322_b.jpg" onclick="openLightbox(this.src)">
      <div class="photo-info">Lights of the night city</div>
    </div>

  </div>
</section>

<section id="animals">
  <h2>Kingdom of Creatures</h2>
  <div class="gallery">

    <div class="photo-card">
      <img src="https://media.istockphoto.com/id/1064136288/photo/she-bear-and-cubs.jpg?s=612x612&w=0&k=20&c=yawood030on-Gw0fAnEPO6JyrHw8Fflr7-S_ZOmPwJU=" onclick="openLightbox(this.src)">
      <div class="photo-info">Wildlife in natural habitat</div>
    </div>

    <div class="photo-card">
      <img src="https://images.stockcake.com/public/8/3/5/835da204-3699-4a0e-ad97-1e94f84653e2_large/sunset-beach-horses-stockcake.jpg" onclick="openLightbox(this.src)">
      <div class="photo-info">Close encounter with nature</div>
    </div>

    <div class="photo-card">
      <img src="https://i.pinimg.com/736x/6b/3b/b9/6b3bb96396d41a4f0ee49230d045694a.jpg" onclick="openLightbox(this.src)">
      <div class="photo-info">Majestic creatures</div>
    </div>

  </div>
</section>

<div class="lightbox" id="lightbox">
  <span class="close-btn" onclick="closeLightbox()">&times;</span>
  <img id="lightbox-img">
</div>

<footer>
  © 2026 Midnight Aperture Photography
</footer>

<script>
function openLightbox(src){
  document.getElementById('lightbox').style.display='flex';
  document.getElementById('lightbox-img').src=src;
}

function closeLightbox(){
  document.getElementById('lightbox').style.display='none';
}

document.getElementById('lightbox').addEventListener('click',function(e){
  if(e.target.id==='lightbox') closeLightbox();
});

document.addEventListener('keydown',function(e){
  if(e.key==='Escape') closeLightbox();
});
</script>

</body>
</html>
